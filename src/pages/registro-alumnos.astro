---
import "../layouts/Layout.astro";
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Registro de Alumnos - CBTis No. 224</title>
  <link rel="icon" type="image/png" href="/img/logo.png" />
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;800&family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">
</head>
<body>
  <header class="header" style="background:var(--negro-cbtis);border-bottom:4px solid var(--rojo-cbtis);padding:1rem;">
    <div style="max-width:1200px;margin:0 auto;">
      <a href="/" style="color:var(--rojo-cbtis);font-weight:800;font-size:1.5rem;text-decoration:none;">
        CBTis No. 224
      </a>
      <a href="/" style="float:right;color:#fff;text-decoration:none;margin-top:0.3rem;">Volver al Inicio</a>
    </div>
  </header>
  <main class="main-container form-page page-fade-in show">
    <section class="banner-section form-banner">
      <div class="banner-overlay form-overlay">
        <h1>Registro de Alumnos</h1>
        <p>Completa tus datos para registrarte</p>
      </div>
    </section>

    <div class="form-container">
      <div class="caja-formulario">
        <h3 class="section-title">Datos del Alumno</h3>
        <form id="formAlumno">
          <div class="input-group">
            <label for="numControl">Número de Control</label>
            <input type="text" id="numControl" placeholder="Ej. 2432502240001" required>
          </div>
          
          <div class="input-group">
            <label for="nombre">Nombre(s)</label>
            <input type="text" id="nombre" placeholder="Nombre completo" required>
          </div>
          
          <div class="row-group">
            <div class="input-group">
              <label for="apP">Apellido Paterno</label>
              <input type="text" id="apP" placeholder="Apellido paterno" required>
            </div>
            <div class="input-group">
              <label for="apM">Apellido Materno</label>
              <input type="text" id="apM" placeholder="Apellido materno" required>
            </div>
          </div>
          
          <div class="row-group">
            <div class="input-group">
              <label for="turno">Turno</label>
              <input type="text" id="turno" placeholder="Matutino / Vespertino" required>
            </div>
            <div class="input-group">
              <label for="grupo">Grupo</label>
              <input type="text" id="grupo" placeholder="Ej. 1A" required>
            </div>
          </div>
          
          <button type="submit" class="boton-enviar">Establecer Registro</button>
        </form>
        <div id="mensajeStatus" class="mensaje-status"></div>
      </div>
    </div>
  </main>

<script>
  window.addEventListener('DOMContentLoaded', () => {
    const main = document.querySelector(".main-container");
    if (main) main.classList.add("show");
  });

  const form = document.getElementById('formAlumno') as HTMLFormElement;
  const msgDiv = document.getElementById('mensajeStatus') as HTMLDivElement;

  if (form) {
    form.onsubmit = async (e) => {
      e.preventDefault();

      msgDiv.textContent = 'Enviando...';
      msgDiv.className = 'mensaje-status enviando';

      const datos = {
        numControl: (document.getElementById('numControl') as HTMLInputElement).value,
        nombre: (document.getElementById('nombre') as HTMLInputElement).value,
        apellidoP: (document.getElementById('apP') as HTMLInputElement).value,
        apellidoM: (document.getElementById('apM') as HTMLInputElement).value,
        turno: (document.getElementById('turno') as HTMLInputElement).value,
        grupo: (document.getElementById('grupo') as HTMLInputElement).value
      };

      try {
        const peticion = await fetch('http://localhost:3000/enviar', {
          method: 'POST',
          headers: {'Content-Type': 'application/json'},
          body: JSON.stringify(datos)
        });

        if (peticion.ok) {
          msgDiv.textContent = 'Alumno Guardado con exito';
          msgDiv.className = 'mensaje-status exito';
          form.reset();
        } else {
          msgDiv.textContent = 'No se pudo guardar el alumno';
          msgDiv.className = 'mensaje-status error';
        }
      } catch (error) {
        console.log('error fatal:', error);
        msgDiv.textContent = 'Error de servidor o red';
        msgDiv.className = 'mensaje-status error';
      }
    }
  }
</script>

<style>
  :root {
    --rojo-cbtis: #a9211f;
    --negro-cbtis: #181818;
    --gris-oscuro: #232323;
    --blanco: #fff;
    --gris-texto: #e0e0e0;
    --gris-borde: #333;
    --rojo-hover: #d32f2f;
  }
  
  .form-page {
    min-height: 100vh;
    padding-bottom: 4rem;
  }

  .form-banner {
    height: 180px;
  }

  .form-overlay h1 {
    font-size: 2.5rem;
    color: var(--blanco);
    text-shadow: 2px 2px 8px #000;
  }

  .form-container {
    max-width: 700px;
    margin: 3rem auto;
    padding: 0 1rem;
  }

  .caja-formulario {
    background: rgba(35, 35, 35, 0.65);
    backdrop-filter: blur(8px) saturate(1.2);
    padding: 2.5rem;
    border-radius: 18px;
    box-shadow: 0 4px 32px rgba(0, 0, 0, 0.3);
    border: 1.5px solid var(--gris-borde);
  }

  .section-title {
    font-size: 1.8rem;
    font-weight: 800;
    color: var(--rojo-cbtis);
    margin-bottom: 2rem;
    letter-spacing: 1px;
    text-align: center;
  }
  
  .input-group {
    margin-bottom: 1.5rem;
    display: flex;
    flex-direction: column;
  }

  .row-group {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  label {
    margin-bottom: 0.5rem;
    font-weight: 600;
    color: var(--gris-texto);
    font-size: 0.95rem;
  }

  input {
    width: 100%;
    padding: 12px 16px;
    background: #1e1e1e;
    border: 1px solid #444;
    border-radius: 8px;
    color: var(--blanco);
    font-size: 1rem;
    font-family: inherit;
    transition: border-color 0.3s, box-shadow 0.3s;
    box-sizing: border-box;
  }

  input::placeholder {
    color: #888;
  }

  input:focus {
    outline: none;
    border-color: var(--rojo-cbtis);
    box-shadow: 0 0 0 3px rgba(169, 33, 31, 0.2);
  }

  .boton-enviar {
    width: 100%;
    padding: 14px;
    background: linear-gradient(135deg, var(--rojo-cbtis), #851817);
    color: var(--blanco);
    font-size: 1.1rem;
    font-weight: 700;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    margin-top: 1rem;
    transition: transform 0.2s, box-shadow 0.2s, background 0.2s;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .boton-enviar:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(169, 33, 31, 0.3);
    background: linear-gradient(135deg, var(--rojo-hover), #a9211f);
  }

  .mensaje-status {
    margin-top: 1.5rem;
    padding: 1rem;
    border-radius: 8px;
    text-align: center;
    font-weight: 600;
    display: none;
  }

  .mensaje-status.enviando {
    display: block;
    background: #333;
    color: var(--blanco);
    border: 1px solid #555;
  }

  .mensaje-status.exito {
    display: block;
    background: rgba(40, 167, 69, 0.1);
    color: #4caf50;
    border: 1px solid #28a745;
  }

  .mensaje-status.error {
    display: block;
    background: rgba(169, 33, 31, 0.1);
    color: #ff5252;
    border: 1px solid var(--rojo-cbtis);
  }

  @media (max-width: 600px) {
    .row-group {
      grid-template-columns: 1fr;
      gap: 0;
    }
    .caja-formulario {
      padding: 1.5rem;
    }
    .form-overlay h1 {
      font-size: 1.8rem;
    }
  }
</style>
</body>
</html>
