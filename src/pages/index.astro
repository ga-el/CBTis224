  body {
    background: var(--negro-cbtis);
    color: var(--gris-texto);
    font-family: "Montserrat", "Roboto", Arial, sans-serif;
    margin: 0;
    min-height: 100vh;
  }
  .header {
    background: var(--negro-cbtis);
    border-bottom: 4px solid var(--rojo-cbtis);
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.12);
    position: sticky;
    top: 0;
    z-index: 100;
  }
  a {
    text-decoration: none;
    color: inherit;
  }
  .header-container {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.7rem 2rem;
  }
  .institucion {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--rojo-cbtis);
    letter-spacing: 1px;
    line-height: 1.1;
    text-shadow: 1px 1px 8px #000;
  }

  .institucion .sub {
    font-size: 1rem;
    color: var(--gris-texto);
    font-weight: 400;
    display: block;
  }
  .menu {
    list-style: none;
    display: flex;
    gap: 32px;
    align-items: center;
    margin: 0;
    padding: 0;
  }
  .menu > li {
    position: relative;
    font-size: 1.08rem;
    font-weight: 600;
    letter-spacing: 0.5px;
    transition: color 0.2s;
  }
  .menu > li > a {
    color: var(--blanco);
    text-decoration: none;
    padding: 16px 22px 14px 22px;
    border-radius: 8px 8px 0 0;
    display: flex;
    align-items: center;
    transition: background 0.18s, color 0.18s;
    position: relative;
  }
  .menu > li > a:hover, .menu > li > a:focus {
    background: var(--gris-borde);
    color: var(--rojo-hover);
  }
  .menu > li.dropdown > a::after {
    content: '\25BC';
    font-size: 0.7em;
    margin-left: 7px;
    transition: transform 0.2s;
  }
  .menu > li.dropdown:hover > a::after {
    transform: rotate(-180deg);
  }
  /* Submenú principal */
  .submenu {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    min-width: 230px;
    background: #233;
    border-radius: 0 0 12px 12px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.22), 0 2px 8px rgba(0,0,0,0.18);
    padding: 10px 0;
    z-index: 9999;
    border: 1.5px solid var(--rojo-cbtis);
    animation: fadeInMenu 0.22s cubic-bezier(.4,2,.6,1);
  }
  @keyframes fadeInMenu {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: none; }
  }
  .dropdown:hover > .submenu, .dropdown:focus-within > .submenu {
    display: block;
  }
  .submenu li {
    position: relative;
  }
  .submenu li a {
    color: var(--blanco);
    text-decoration: none;
    padding: 12px 24px;
    display: block;
    border-radius: 6px;
    font-size: 1rem;
    font-weight: 500;
    transition: background 0.18s, color 0.18s, padding-left 0.18s;
  }
  .submenu li a:hover, .submenu li a:focus {
    background: var(--rojo-cbtis);
    color: var(--blanco);
    padding-left: 32px;
  }
  /* Submenús anidados */
  .submenu .dropdown > a::after {
    content: '\25B6';
    font-size: 0.7em;
    margin-left: 8px;
    float: right;
    transition: transform 0.2s;
  }
  .submenu .dropdown:hover > a::after {
    transform: translateX(4px);
  }
  .submenu .dropdown .submenu {
    position: absolute;
    top: 0;
    border-radius: 8px;
    min-width: 210px;
    background: #222b2b;
    box-shadow: 0 8px 32px rgba(0,0,0,0.18), 0 2px 8px rgba(0,0,0,0.13);
    border: 1.5px solid var(--rojo-cbtis);
    padding: 8px 0;
    animation: fadeInMenu 0.22s cubic-bezier(.4,2,.6,1);
    /* Posicionamiento inteligente para evitar desbordamiento */
    left: 100%;
  }
  /* Corregir desbordamiento del submenú anidado */
  .submenu .dropdown:last-child .submenu,
  .submenu .dropdown:nth-last-child(2) .submenu {
    left: -100%;
    right: 100%;
  }
  /* Media query para pantallas pequeñas */
  @media (max-width: 1400px) {
    .submenu .dropdown .submenu {
      left: -100%;
      right: 100%;
    }
  }
  /* Separadores visuales entre items */
  .submenu li:not(:last-child) a {
    border-bottom: 1px solid rgba(255,255,255,0.07);
  }
  /* Responsive */
  @media (max-width: 900px) {
    .header-container {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.7rem;
      padding: 1rem 1rem;
    }
    .menu {
      gap: 10px;
      font-size: 0.98rem;
    }
    .menu > li > a {
      padding: 12px 12px 10px 12px;
      font-size: 1rem;
    }
    .submenu {
      min-width: 170px;
      font-size: 0.98rem;
    }
  }
  @media (max-width: 600px) {
    .header-container {
      padding: 0.5rem 0.3rem;
    }
    .menu {
      flex-direction: column;
      gap: 0;
      width: 100%;
    }
    .menu > li {
      width: 100%;
    }
    .menu > li > a {
      width: 100%;
      border-radius: 0;
      padding: 14px 10px;
    }
    .submenu {
      left: 0;
      min-width: 100vw;
      border-radius: 0 0 12px 12px;
    }
  }
  .nav {
    display: flex;
    gap: 2.2rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .nav {
    color: var(--blanco);
    font-weight: 600;
    font-size: 1.1rem;
    letter-spacing: 0.5px;
    cursor: pointer;
    position: relative;
    transition: color 0.2s;
  }
  .nav li:hover {
    color: var(--rojo-hover);
  }
  .nav li::after {
    content: "";
    display: block;
    margin: 0 auto;
    width: 0%;
    height: 2px;
    background: var(--rojo-cbtis);
    transition: width 0.3s;
  }
  .nav li:hover::after {
    width: 100%;
  }
  @media (max-width: 800px) {
    .header-container {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.7rem;
      padding: 1rem 1rem;
    }
    .nav {
      gap: 1.2rem;
    }
    .institucion {
      font-size: 1.1rem;
    }
  }
  .main-container {
    background: var(--gris-oscuro);
    color: var(--gris-texto);
    min-height: 100vh;
    padding-bottom: 0;
  }
  .page-fade-in {
    opacity: 0;
    transform: translateY(40px) scale(0.98);
    transition:
      opacity 1.1s cubic-bezier(0.4, 2, 0.6, 1),
      transform 1.1s cubic-bezier(0.4, 2, 0.6, 1);
  }
  .page-fade-in.show {
    opacity: 1;
    transform: none;
  }

  .banner-section {
    position: relative;
    width: 100%;
    height: 340px;
    background: var(--rojo-cbtis);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    border-bottom: 6px solid var(--negro-cbtis);
  }
  .banner-img {
    width: 100%;
    height: 340px;
    object-fit: cover;
    opacity: 0.7;
    filter: grayscale(10%) contrast(1.1);
  }
  .banner-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    color: var(--blanco);
    background: rgba(25, 25, 25, 0.45);
    text-shadow: 1px 1px 12px #000;
    font-size: 1.2rem;
  }
  .banner-overlay h1 {
    font-size: 2.8rem;
    font-weight: 800;
    letter-spacing: 2px;
    margin: 0 0 0.5rem 0;
    color: var(--blanco);
    text-transform: uppercase;
  }
  .banner-overlay p {
    font-size: 1.2rem;
    color: #ffeaea;
    margin: 0;
  }
  .noticias-section,
  .convocatorias-section,
  .ubicacion-section {
    margin: 2.5rem auto 2rem auto;
    max-width: 1200px;
    padding: 2rem 2rem 1.5rem 2rem;
    background: var(--gris-oscuro);
    border-radius: 18px;
    box-shadow: 0 4px 32px rgba(0, 0, 0, 0.18);
    border: 1.5px solid var(--gris-borde);
  }
  .noticias-section h2,
  .convocatorias-section h2,
  .ubicacion-section h2 {
    color: var(--rojo-cbtis);
    font-size: 2rem;
    margin-bottom: 1.2rem;
    font-weight: 700;
    letter-spacing: 1px;
  }
  .noticias-grid,
  .convocatorias-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.5rem;
  }
  .noticia-img,
  .convocatoria-img {
    width: 100%;
    border-radius: 18px;
    border: 3px solid var(--rojo-cbtis);
    box-shadow:
      0 4px 24px rgba(169, 33, 31, 0.1),
      0 2px 8px rgba(0, 0, 0, 0.1);
    background: var(--blanco);
    transition:
      transform 0.2s,
      box-shadow 0.2s;
  }
  .noticia-img:hover,
  .convocatoria-img:hover {
    transform: scale(1.04) translateY(-4px);
    box-shadow:
      0 8px 32px rgba(169, 33, 31, 0.18),
      0 4px 16px rgba(0, 0, 0, 0.18);
    z-index: 2;
  }
  .ubicacion-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    align-items: start;
    background: #222;
    border-radius: 16px;
    padding: 1.5rem;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    border: 1.5px solid var(--rojo-cbtis);
  }
  .ubicacion-info {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .ubicacion-info h3 {
    color: var(--rojo-cbtis);
    font-size: 1.3rem;
    font-weight: 700;
    margin: 0;
    letter-spacing: 0.5px;
  }
  .ubicacion-info p {
    color: var(--gris-texto);
    font-size: 1.1rem;
    margin: 0;
    line-height: 1.5;
  }
  .ubicacion-info a {
    color: var(--rojo-cbtis);
    text-decoration: none;
    font-weight: 600;
  }
  .ubicacion-info a:hover {
    text-decoration: underline;
  }
  .ubicacion-mapa {
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
  }
  .ubicacion-card iframe {
    border-radius: 12px;
    border: 2px solid var(--rojo-cbtis);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    width: 100%;
  }
  .footer {
    background: var(--negro-cbtis);
    color: var(--gris-texto);
    padding: 2rem 0 1rem 0;
    margin-top: 3rem;
    border-top: 4px solid var(--rojo-cbtis);
  }
  .footer-content {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    max-width: 1200px;
    margin: 0 auto;
    gap: 2rem;
  }
  .footer-content h3 {
    color: var(--rojo-cbtis);
    font-size: 1.2rem;
    margin-bottom: 0.7rem;
    font-weight: 700;
  }
  .footer-content ul {
    list-style: disc inside;
    padding-left: 0;
    margin: 0;
  }
  .footer-content li {
    margin-bottom: 0.4rem;
    color: var(--gris-texto);
    font-size: 1rem;
  }
  .footer-social img {
    width: 44px;
    margin-right: 1rem;
    border-radius: 8px;
    background: var(--gris-oscuro);
    border: 2px solid var(--rojo-cbtis);
    transition: box-shadow 0.2s;
  }
  .footer-social img:hover {
    box-shadow: 0 2px 12px var(--rojo-cbtis);
  }
  .footer-bottom {
    text-align: center;
    margin-top: 1.5rem;
    color: #bbb;
    font-size: 1rem;
    letter-spacing: 1px;
  }
  @media (max-width: 900px) {
    .footer-content,
    .noticias-section,
    .convocatorias-section,
    .ubicacion-section {
      max-width: 98vw;
      padding: 1rem 0.5rem;
    }
    .ubicacion-card {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }
  @media (max-width: 600px) {
    .banner-section,
    .banner-img {
      height: 180px;
    }
    .banner-overlay h1 {
      font-size: 1.3rem;
    }
    .banner-overlay p {
      font-size: 0.9rem;
    }
    .noticias-section h2,
    .convocatorias-section h2,
    .ubicacion-section h2 {
      font-size: 1.2rem;
    }
    .header-container {
      padding: 0.5rem 0.3rem;
    }
  }
  .section-title {
    font-size: 1.6rem;
    font-weight: 800;
    color: var(--rojo-cbtis);
    margin-bottom: 1.2rem;
    letter-spacing: 1px;
    text-align: left;
    position: relative;
  }
  .section-title::after {
    content: "";
    display: block;
    width: 40px;
    height: 3px;
    background: var(--rojo-cbtis);
    border-radius: 2px;
    margin-top: 0.3rem;
  }
  .noticias-section.mejorada,
  .convocatorias-section.mejorada {
    background: var(--gris-oscuro);
    border-radius: 18px;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.13);
    border: 1.5px solid var(--gris-borde);
    margin-bottom: 2rem;
    padding: 1.5rem 1rem 1.2rem 1rem;
  }
  .noticias-grid.mejorada,
  .convocatorias-grid.mejorada {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.1rem;
    margin-top: 0.5rem;
  }
  .card {
    background: rgba(35, 35, 35, 0.65);
    backdrop-filter: blur(8px) saturate(1.2);
    border-radius: 18px;
    box-shadow:
      0 4px 24px rgba(169, 33, 31, 0.1),
      0 2px 8px rgba(0, 0, 0, 0.1);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    min-height: 180px;
    border: 1.5px solid rgba(255, 255, 255, 0.08);
    cursor: pointer;
    position: relative;
    opacity: 0;
    transform: scale(0.96) translateY(40px);
    filter: blur(8px);
    transition:
      opacity 0.9s cubic-bezier(0.4, 2, 0.6, 1),
      transform 0.9s cubic-bezier(0.4, 2, 0.6, 1),
      filter 0.9s cubic-bezier(0.4, 2, 0.6, 1),
      box-shadow 0.3s,
      filter 0.25s,
      transform 0.25s;
  }
  .card.scroll-animate {
    opacity: 1;
    transform: scale(1) translateY(0);
    filter: none;
    box-shadow:
      0 8px 32px rgba(169, 33, 31, 0.18),
      0 4px 16px rgba(0, 0, 0, 0.18);
  }
  .card:hover {
    transform: scale(1.04) translateY(-3px);
    box-shadow:
      0 12px 32px rgba(169, 33, 31, 0.18),
      0 4px 16px rgba(0, 0, 0, 0.18);
    filter: brightness(1.13) contrast(1.13) saturate(1.13);
    z-index: 2;
  }
  .card img {
    width: 100%;
    height: 110px;
    object-fit: cover;
    border-bottom: 1.5px solid var(--rojo-cbtis);
    background: #fff;
    transition:
      filter 0.18s,
      transform 0.18s;
  }
  /* Elimina el hover individual de la imagen */
  .card:hover img {
    filter: none;
    transform: none;
    transition: none;
  }
  .card-content {
    padding: 0.7rem 0.7rem 0.6rem 0.7rem;
    flex: 1;
    display: flex;
    align-items: flex-start;
    justify-content: flex-start;
    flex-direction: column;
  }
  .card-content h3 {
    font-size: 1rem;
    font-weight: 600;
    color: var(--blanco);
    margin: 0;
    margin-top: 0.3rem;
    letter-spacing: 0.2px;
    line-height: 1.25;
    text-shadow: 0 1px 4px #0007;
  }
  @media (max-width: 700px) {
    .noticias-grid.mejorada,
    .convocatorias-grid.mejorada {
      grid-template-columns: 1fr;
      gap: 0.7rem;
    }
    .noticias-section.mejorada,
    .convocatorias-section.mejorada {
      padding: 0.7rem 0.2rem 0.7rem 0.2rem;
    }
    .section-title {
      font-size: 1.1rem;
    }
    .card {
      min-height: 120px;
    }
    .card img {
      height: 70px;
    }
    .card-content h3 {
      font-size: 0.92rem;
    }
  }
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .fade-in {
    animation: fadeInUp 0.7s cubic-bezier(0.4, 2, 0.6, 1);
  }
  .conocenos-btn-container {
    display: flex;
    justify-content: center;
    margin: 1.5rem 0 0.5rem 0;
  }
  .conocenos-btn {
    background: var(--rojo-cbtis);
    color: var(--blanco);
    font-size: 1.08rem;
    font-weight: 600;
    padding: 0.7rem 2.2rem;
    border: none;
    border-radius: 32px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.10);
    transition: background 0.18s, color 0.18s, transform 0.18s, box-shadow 0.18s;
    cursor: pointer;
    text-decoration: none;
    letter-spacing: 0.5px;
    outline: none;
    display: inline-block;
  }
  .conocenos-btn:hover, .conocenos-btn:focus {
    background: var(--rojo-hover);
    color: var(--blanco);
    transform: translateY(-2px) scale(1.04);
    box-shadow: 0 4px 18px rgba(169,33,31,0.18);
  }
  .botones-acceso-container {
    display: flex;
    justify-content: center;
    margin: 2.5rem 0 1rem 0;
  }
  .boton-registro-destacado {
    background: linear-gradient(135deg, var(--rojo-cbtis), #851817);
    color: var(--blanco);
    font-size: 1.25rem;
    font-weight: 700;
    padding: 0.9rem 2.8rem;
    border: none;
    border-radius: 32px;
    box-shadow: 0 4px 18px rgba(169, 33, 31, 0.3);
    text-transform: uppercase;
    letter-spacing: 1px;
    transition: transform 0.2s, box-shadow 0.2s, background 0.2s;
    cursor: pointer;
    text-decoration: none;
  }
  .boton-registro-destacado:hover, .boton-registro-destacado:focus {
    transform: translateY(-3px) scale(1.03);
    box-shadow: 0 8px 24px rgba(169, 33, 31, 0.4);
    background: linear-gradient(135deg, var(--rojo-hover), #a9211f);
    color: var(--blanco);
  }

  .botones-discretos-container {
    display: flex;
    justify-content: center;
    gap: 1.2rem;
    margin: 1.2rem 0 0.5rem 0;
  }
  .boton-discreto {
    background: transparent;
    color: var(--gris-texto);
    font-size: 1rem;
    font-weight: 500;
    padding: 0.4rem 1.3rem;
    border: 1.2px solid var(--gris-borde);
    border-radius: 22px;
    transition: background 0.15s, color 0.15s, border 0.15s;
    cursor: pointer;
    text-decoration: none;
    letter-spacing: 0.2px;
    outline: none;
    box-shadow: none;
    opacity: 0.85;
  }
  .boton-discreto:hover, .boton-discreto:focus {
    background: var(--gris-borde);
    color: var(--rojo-cbtis);
    border-color: var(--rojo-cbtis);
    opacity: 1;
  }
  .conocenos-btn-container, .conocenos-btn {
    display: none !important;
  }
  /* Hamburguesa */
  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    width: 44px;
    height: 44px;
    background: rgba(34, 34, 34, 0.95);
    border: 2px solid var(--rojo-cbtis);
    border-radius: 10px;
    cursor: pointer;
    z-index: 1200;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    backdrop-filter: blur(8px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
  }
  .hamburger:hover {
    background: rgba(169, 33, 31, 0.9);
    transform: scale(1.05);
    box-shadow: 0 6px 20px rgba(169, 33, 31, 0.3);
  }
  .hamburger.active {
    background: var(--rojo-cbtis);
    transform: scale(0.95);
  }
  .hamburger span {
    display: block;
    width: 26px;
    height: 3px;
    margin: 3px 0;
    background: var(--blanco);
    border-radius: 2px;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    transform-origin: center;
  }
  .hamburger.active span:nth-child(1) {
    transform: rotate(45deg) translate(6px, 6px);
  }
  .hamburger.active span:nth-child(2) {
    opacity: 0;
    transform: scale(0);
  }
  .hamburger.active span:nth-child(3) {
    transform: rotate(-45deg) translate(6px, -6px);
  }
  .header-container {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.7rem 2rem;
  }
  .desktop-header-container {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.7rem 2rem;
  }
  @media (max-width: 1200px) {
    .nav#desktop-nav {
      display: none !important;
    }
    .desktop-header-container {
      display: none !important;
    }
    .hamburger {
      display: flex !important;
      position: fixed;
