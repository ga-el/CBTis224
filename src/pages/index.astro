  /* Menú móvil */
  .mobile-menu {
    display: none;
    position: fixed;
    top: 0;
    right: 0;
    left: auto;
    width: min(90vw, 420px);
    height: 100vh;
    background: linear-gradient(
      135deg, 
      rgba(20, 20, 20, 0.98) 0%, 
      rgba(35, 35, 35, 0.98) 50%,
      rgba(25, 25, 25, 0.98) 100%
    );
    backdrop-filter: blur(25px) saturate(1.3);
    border-left: 4px solid var(--rojo-cbtis);
    box-shadow: 
      -12px 0 48px rgba(0, 0, 0, 0.4),
      -4px 0 16px rgba(0, 0, 0, 0.2),
      inset 1px 0 0 rgba(255, 255, 255, 0.05);
    z-index: 2000;
    flex-direction: column;
    padding: 0;
    overflow-y: auto;
    overflow-x: hidden;
    transition: all 0.45s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    transform: translateX(100%);
    pointer-events: none;
    opacity: 0;
    scrollbar-width: thin;
    scrollbar-color: var(--rojo-cbtis) rgba(255, 255, 255, 0.1);
  }
  
  .mobile-menu::-webkit-scrollbar {
    width: 6px;
  }
  .mobile-menu::-webkit-scrollbar-track {
    background: rgba(255, 255, 255, 0.05);
    border-radius: 3px;
  }
  .mobile-menu::-webkit-scrollbar-thumb {
    background: var(--rojo-cbtis);
    border-radius: 3px;
  }
  .mobile-menu::-webkit-scrollbar-thumb:hover {
    background: var(--rojo-hover);
  }
  @media (max-width: 1200px) {
    .mobile-menu {
      display: flex;
    }
  }
  .mobile-menu.open {
    transform: translateX(0);
    pointer-events: auto;
    opacity: 1;
    animation: slideInRight 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  @keyframes slideInRight {
    from {
      transform: translateX(100%);
      opacity: 0;
    }
    to {
      transform: translateX(0);
      opacity: 1;
    }
  }
  .mobile-menu .close-mobile-menu {
    background: none;
    border: none;
    color: var(--blanco);
    font-size: 2.2rem;
    align-self: flex-end;
    margin-bottom: 1.2rem;
    cursor: pointer;
  }
  .mobile-menu .menu {
    flex-direction: column;
    gap: 0.2rem;
  }
  .mobile-menu .submenu {
    display: none;
    position: static;
    background: none;
    box-shadow: none;
    border: none;
    padding: 0;
    min-width: 0;
    animation: none;
  }
  .mobile-menu .submenu.open {
    display: block;
  }
  .mobile-menu .dropdown > a::after {
    content: '\25BC';
    float: right;
    margin-left: 8px;
    font-size: 0.8em;
    transition: transform 0.2s;
  }
  .mobile-menu .submenu .dropdown > a::after {
    content: '\25B6';
    float: right;
    margin-left: 8px;
    font-size: 0.8em;
  }
  .mobile-menu-backdrop {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(4px);
    z-index: 1500;
    transition: all 0.3s ease;
    opacity: 0;
    pointer-events: none;
  }
  .mobile-menu-backdrop.show {
    display: block;
    opacity: 1;
    pointer-events: auto;
    animation: fadeInBackdrop 0.3s ease;
  }
  @keyframes fadeInBackdrop {
    from { opacity: 0; }
    to { opacity: 1; }
  }
