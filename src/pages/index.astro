<script>
  window.addEventListener("DOMContentLoaded", () => {
    const hamburgerBtn = document.getElementById('hamburger-btn');
    if (!hamburgerBtn) { console.log('No se encontró el botón hamburguesa'); return; }
    const mobileMenu = document.getElementById('mobile-menu');
    const closeMobileMenu = document.getElementById('close-mobile-menu');
    const mobileMenuBackdrop = document.getElementById('mobile-menu-backdrop');
    
    // Animación de entrada global
    const main = document.querySelector(".main-container");
    if (main) main.classList.add("show");
    
    // Animaciones al hacer scroll para .card
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("scroll-animate");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15 }
    );
    document.querySelectorAll(".card").forEach((card) => {
      observer.observe(card);
    });
    
    // Funciones del menú hamburguesa
    function openMobileMenu() {
      console.log('Abriendo menú hamburguesa');
      if (mobileMenu && mobileMenuBackdrop && hamburgerBtn) {
        mobileMenu.classList.add('open');
        mobileMenuBackdrop.classList.add('show');
        hamburgerBtn.setAttribute('aria-expanded', 'true');
        mobileMenu.setAttribute('aria-hidden', 'false');
        hamburgerBtn.classList.add('active');
        document.body.style.overflow = 'hidden';
      }
    }
    
    function closeMobileMenuFunc() {
      if (mobileMenu && mobileMenuBackdrop && hamburgerBtn) {
        mobileMenu.classList.remove('open');
        mobileMenuBackdrop.classList.remove('show');
        hamburgerBtn.setAttribute('aria-expanded', 'false');
        mobileMenu.setAttribute('aria-hidden', 'true');
        hamburgerBtn.classList.remove('active');
        document.body.style.overflow = '';
      }
    }
    
    // Event listeners para el menú hamburguesa
    hamburgerBtn.addEventListener('click', openMobileMenu);
    hamburgerBtn.addEventListener('keydown', (e) => { 
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        openMobileMenu();
      }
    });
    
    if (closeMobileMenu) closeMobileMenu.addEventListener('click', closeMobileMenuFunc);
    if (mobileMenuBackdrop) mobileMenuBackdrop.addEventListener('click', closeMobileMenuFunc);
    
    // Cerrar menú con tecla Escape
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && mobileMenu.classList.contains('open')) {
        closeMobileMenuFunc();
      }
    });
    
    // Submenús tipo acordeón en móvil con animación mejorada
    document.querySelectorAll('.mobile-menu .dropdown > a').forEach(link => {
      link.addEventListener('click', function(e) {
        e.preventDefault();
        const submenu = this.nextElementSibling;
        const arrow = this.querySelector('.submenu-arrow');
        
        // Cerrar otros submenús del mismo nivel
        const parentMenu = this.closest('.menu, .submenu');
        if (parentMenu) {
          const otherDropdowns = parentMenu.querySelectorAll(':scope > .dropdown');
          otherDropdowns.forEach(dropdown => {
            if (dropdown !== this.parentElement) {
              const otherSubmenu = dropdown.querySelector('.submenu');
              const otherArrow = dropdown.querySelector('.submenu-arrow');
              if (otherSubmenu && otherSubmenu.classList.contains('open')) {
                otherSubmenu.classList.remove('open');
                if (otherArrow) {
                  otherArrow.style.transform = 'rotate(0deg)';
                }
              }
            }
          });
        }
        
        if (submenu && submenu.classList.contains('submenu')) {
          submenu.classList.toggle('open');
          if (arrow) {
            arrow.style.transform = submenu.classList.contains('open') ? 'rotate(90deg)' : 'rotate(0deg)';
          }
        }
      });
    });
  });
</script>

